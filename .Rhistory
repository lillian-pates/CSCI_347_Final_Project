library(tidyverse)
library(tidymodels)
library(glmnet)
data(ames)
set.seed(123)
## Splitting smaple into training/test dataset
ames_split = initial_split(ames, prop= 0.8)
ames_train = ames_split |> training()
ames_test  = ames_split |> testing()
##Recipe building
model_simple = lm(Sale_Price~ Year_Built + Gr_Liv_Area, data = ames_train)
## add fitted and residuals
ames_with = augment(model_simple, new_data = ames_train)
##compute rmse
mse_simple = mean(ames_with$.resid^2)
rmse_simple = sqrt(mse_simple)
##get the mean
mean_sales = mean(ames_train$Sale_Price)
rmse_simple
mean_sales
## plot predictions against true values
ggplot(ames_with, aes( x = .fitted, y = Sale_Price)) +
geom_point(color = "blue") +
geom_abline()
##Adding more variables
model_more = lm(Sale_Price~Year_Built + Gr_Liv_Area+ MS_SubClass+ MS_Zoning+Neighborhood+ Overall_Cond+Lot_Frontage+Lot_Shape, data = ames_train)
## add fitted and residuals
ames_more = augment(model_more, new_data = ames_train)
##compute rmse
mse_more = mean(ames_more$.resid^2)
rmse_more = sqrt(mse_more)
rmse_more
## plot predictions against true values
ggplot(ames_more, aes( x = .fitted, y = Sale_Price)) +
geom_point(color = "blue") +
geom_abline()
##adding all the variables
model_all = lm(Sale_Price~., data = ames_train)
## add fitted and residuals
ames_all = augment(model_all, new_data = ames_train)
##compute rmse
mse_all = mean(ames_all$.resid^2)
rmse_all = sqrt(mse_all)
rmse_all
## plot predictions against true values
ggplot(ames_all, aes( x = .fitted, y = Sale_Price)) +
geom_point(color = "blue") +
geom_abline()
##basic model
test_preds_1 = augment(model_simple, new_data = ames_test)
rmse_test_1 = sqrt(mean(test_preds_1$.resid^2))
## more model
test_preds_2 = augment(model_more, new_data = ames_test)
rmse_test_2 = sqrt(mean(test_preds_2$.resid^2))
## all variables model
test_preds_3 = augment(model_all, new_data = ames_test)
rmse_test_3 = sqrt(mean(test_preds_3$.resid^2))
## making this so I can compare all three models
rmse_compare = tibble(
model = c("Model 1", "Model 2", "Model 3"),
test_rmse = c(rmse_test_1, rmse_test_2, rmse_test_3)
)
rmse_compare
##Recipe building
ames_recipe = recipe(Sale_Price~., data = ames_train) |>
## create indicators for each categorical or character variable
step_dummy(all_nominal_predictors()) |>
## drop predictors with near 0 var
step_nzv(all_predictors())
## Lasso regression worflow
##define lasso model
model_lasso =
linear_reg(penalty = tune(), mixture = 1) |>
set_engine("glmnet")
## set seed
set.seed(123)
##set up cross-validation
ames_cv = ames_train |> vfold_cv(v = 5)
## 100 lambdas
lambdas = tibble(penalty = seq(0.01, 100000, length.out = 100))
##calculate cross-validated MSE for each value of lambda
workflow_lasso = workflow() |>
add_model(model_lasso) |>
add_recipe(ames_recipe)
##tune with cv
lasso_cv = workflow_lasso |>
tune_grid(
ames_cv,
grid = data.frame(penalty = lambdas),
metrics = metric_set(rmse)
)
##showing the lambdas that performed the best
lasso_cv |> show_best()
# Finalize model with best lambda
best_lambda <- select_best(lasso_cv, metric = "rmse")
final_lasso <- finalize_workflow(workflow_lasso, best_lambda)
# Fit finalized model on full training data
final_lasso_fit <- fit(final_lasso, data = ames_train)
# Predict on test data
lasso_test_preds <- augment(final_lasso_fit, new_data = ames_test)
# Test RMSE
lasso_test_rmse <- lasso_test_preds |>
rmse(truth = Sale_Price, estimate = .predict)
lasso_cv[0]
lasso_cv[1,1]
lasso_cv[1,]
##showing the lambdas that performed the best
lasso_cv |> show_best()
##finalize workflow (designate the value of lambda to take forward)
l_final = workflow_lasso |>
finalize_workflow(select_best(lasso_cv))
##fit model in full training data (all 5 folds) and then make predictions in the test set
reg_fit = l_final |>
last_fit(ames_split)
reg_fit |>
collect_metrics()
##look at coefficients from the best model
coefs = reg_fit |>
extract_fit_parsnip() |>
tidy() |>
View()
##make predictions
test_predictions = reg_fit |>
augment()
##plot predictions vs actual values
ggplot(test_predictions, aes( x = .pred, y = Sale_Price)) +
geom_point(color = "blue") +
geom_abline()
