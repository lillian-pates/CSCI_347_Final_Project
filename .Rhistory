##adding all the variables
model_all = lm(Sale_Price~., data = ames_train) |>
step_dummy(all_nominal_predictors())
## add fitted and residuals
ames_all = augment(model_all, new_data = ames_train)
##compute rmse
mse_all = mean(ames_all$.resid^2)
rmse_all = sqrt(mse_all)
rmse_all
## plot predictions against true values
ggplot(ames_all, aes( x = .fitted, y = Sale_Price)) +
geom_point(color = "blue") +
geom_abline()
##basic model
test_preds_1 = augment(model_simple, new_data = ames_test)
rmse_test_1 = sqrt(mean(test_preds_1$.resid^2))
## more model
test_preds_2 = augment(model_more, new_data = ames_test)
rmse_test_2 = sqrt(mean(test_preds_2$.resid^2))
## all variables model
test_preds_3 = augment(model_all, new_data = ames_test)
rmse_test_3 = sqrt(mean(test_preds_3$.resid^2))
## making this so I can compare all three models
rmse_results = tibble(
model = c("Model 1", "Model 2", "Model 3"),
test_rmse = c(rmse_test_1, rmse_test_2, rmse_test_3)
)
rmse_results
